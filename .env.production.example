PORT=4000
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/liv_collab?schema=public
REDIS_URL=redis://default:<password>@<host>:6379
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
